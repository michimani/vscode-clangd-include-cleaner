{
  "name": "C++ Unused Includes Remover",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "runArgs": ["--name", "vscode-clangd-include-cleaner"],
  "postCreateCommand": "bash .devcontainer/scripts/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome"
      ]
    }
  }
}

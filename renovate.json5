{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'github>hatena/renovate-config:automergeTypesMinor',
    'helpers:pinGitHubActionDigests',
  ],
  reviewers: [
    'michimani',
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^\\.devcontainer/devcontainer\\.json$/',
      ],
      matchStrings: [
        '"image":\\s*"(?<depName>mcr\\.microsoft\\.com/devcontainers/typescript-node):(?<currentValue>[^"]+)"',
      ],
      datasourceTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
      labels: [
        'automerge',
      ],
    },
    {
      groupName: 'Node.js',
      matchPackageNames: [
        'node',
        '@types/node',
        'mcr.microsoft.com/devcontainers/typescript-node',
      ],
    },
  ],
}
